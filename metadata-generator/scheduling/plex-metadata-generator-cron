#!/bin/bash
# Cron-based scheduling for Plex Metadata Generator
# Add to crontab: 0 2 * * * /usr/local/bin/plex-metadata-generator-cron

set -euo pipefail

# Configuration
SCRIPT="/usr/local/bin/plex-metadata-generator"
CONFIG="/etc/plex-metadata-generator.conf"
LOG_DIR="/var/log/plex-metadata-generator"
LOG_FILE="${LOG_DIR}/cron-$(date +%Y%m%d).log"
LOCK_FILE="/var/run/plex-metadata-generator.lock"
LOCK_TIMEOUT=3600  # 1 hour

# Create log directory
mkdir -p "${LOG_DIR}"

# Lock file management to prevent concurrent runs
acquire_lock() {
    if [ -f "${LOCK_FILE}" ]; then
        LOCK_AGE=$(($(date +%s) - $(stat -f%m "${LOCK_FILE}" 2>/dev/null || echo 0)))
        if [ "${LOCK_AGE}" -lt "${LOCK_TIMEOUT}" ]; then
            echo "$(date): Previous instance still running (lock age: ${LOCK_AGE}s)" | tee -a "${LOG_FILE}"
            exit 0
        else
            echo "$(date): Removing stale lock file (age: ${LOCK_AGE}s)" | tee -a "${LOG_FILE}"
            rm -f "${LOCK_FILE}"
        fi
    fi
    touch "${LOCK_FILE}"
}

release_lock() {
    rm -f "${LOCK_FILE}"
}

# Trap to ensure lock is released
trap release_lock EXIT

main() {
    {
        echo "========================================"
        echo "Plex Metadata Generator - Cron Run"
        echo "Started: $(date)"
        echo "========================================"
        
        acquire_lock
        
        if [ ! -f "${CONFIG}" ]; then
            echo "ERROR: Configuration file not found: ${CONFIG}"
            exit 1
        fi
        
        # Run the metadata generator
        ${SCRIPT} --config "${CONFIG}"
        
        local exit_code=$?
        
        echo ""
        echo "========================================"
        echo "Completed: $(date)"
        echo "Exit code: ${exit_code}"
        echo "========================================"
        
        exit ${exit_code}
    } | tee -a "${LOG_FILE}"
}

# Run with CPU and memory limits if available
if command -v nice &> /dev/null; then
    nice -n 10 main
else
    main
fi
